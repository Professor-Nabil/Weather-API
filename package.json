{
  "name": "weather-api-wrapper",
  "version": "1.0.0",
  "description": "A caching weather API wrapper using Express, TypeScript, and Redis.",
  "main": "dist/server.js",
  "type": "module",
  "scripts": {
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "check": "tsc --noEmit",
